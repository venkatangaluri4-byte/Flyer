<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Streetwear Summer Drop</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial,sans-serif;
    }

    body{
      background:#0f0f10;
      color:white;
      overflow-x:hidden;
    }

    .hero{
      position:relative;
      min-height:100vh;

      background:
        linear-gradient(
          180deg,
          rgba(0,0,0,0.2),
          rgba(0,0,0,0.75)
        ),

        linear-gradient(
          135deg,
          #f5dfc4,
          #f3d3ba,
          #d6b49b
        );

      overflow:hidden;

      display:flex;
      align-items:center;
      justify-content:center;

      padding:20px;
    }

    .hero-overlay{
      position:absolute;
      inset:0;

      background:
        radial-gradient(
          circle at top right,
          rgba(255,255,255,0.18),
          transparent 30%
        );
    }

    .hero-content{
      position:absolute;

      top:40px;
      left:24px;
      right:24px;

      z-index:3;
    }

    .badge{
      display:inline-flex;

      padding:10px 18px;

      border-radius:999px;

      background:
        rgba(255,255,255,0.15);

      backdrop-filter:blur(12px);

      font-size:13px;

      font-weight:700;

      margin-bottom:22px;

      letter-spacing:1px;
    }

    h1{
      font-size:54px;

      line-height:0.92;

      font-weight:900;

      letter-spacing:-3px;

      margin-bottom:20px;

      text-shadow:
        0 10px 30px rgba(0,0,0,0.35);
    }

    .hero p{
      font-size:17px;

      line-height:1.6;

      max-width:320px;

      color:
        rgba(255,255,255,0.88);

      margin-bottom:28px;
    }

    .buttons{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
    }

    .btn{
      border:none;

      padding:16px 28px;

      border-radius:18px;

      font-weight:800;

      cursor:pointer;

      font-size:15px;
    }

    .primary-btn{
      background:white;
      color:#111;

      box-shadow:
        0 15px 40px rgba(255,255,255,0.18);
    }

    .secondary-btn{
      background:
        rgba(255,255,255,0.14);

      color:white;

      backdrop-filter:blur(12px);

      border:
        1px solid rgba(255,255,255,0.18);
    }

    .product-image{
      position:absolute;

      width:95%;
      max-width:520px;

      bottom:-20px;

      z-index:2;

      object-fit:contain;

      filter:
        drop-shadow(
          0 30px 60px rgba(0,0,0,0.45)
        );

      animation:float 4s ease-in-out infinite;
    }

    @keyframes float{

      0%,100%{
        transform:translateY(0px);
      }

      50%{
        transform:translateY(-12px);
      }

    }

    .sale-box{
      position:absolute;

      bottom:40px;
      right:24px;

      z-index:4;

      background:
        linear-gradient(
          135deg,
          #ff4d4d,
          #ff6a00
        );

      padding:18px 24px;

      border-radius:24px;

      box-shadow:
        0 20px 50px rgba(255,80,80,0.35);

      animation:pulse 2s infinite;
    }

    @keyframes pulse{

      0%{
        transform:scale(1);
      }

      50%{
        transform:scale(1.05);
      }

      100%{
        transform:scale(1);
      }

    }

    .sale-box small{
      display:block;

      font-size:12px;

      font-weight:700;

      letter-spacing:1px;

      margin-bottom:4px;
    }

    .sale-box h2{
      font-size:42px;

      line-height:1;

      font-weight:900;
    }

    .sale-box span{
      font-size:14px;

      font-weight:700;
    }

    .section{
      padding:28px 20px;
    }

    .section-title{
      font-size:28px;
      font-weight:900;
      margin-bottom:20px;
    }

    .products{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }

    .card{
      background:#1a1a1d;

      border-radius:22px;

      overflow:hidden;

      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .card img{
      width:100%;
      height:220px;
      object-fit:cover;
    }

    .card-content{
      padding:14px;
    }

    .card h3{
      font-size:18px;
      margin-bottom:6px;
    }

    .card p{
      color:#aaa;
      font-size:14px;
    }

    footer{
      text-align:center;

      padding:30px 20px;

      color:#888;

      font-size:14px;
    }

  </style>
</head>

<body>

<section class="hero">

  <div class="hero-overlay"></div>

  <div class="hero-content">

    <div class="badge">
      ☀️ SUMMER DROP 2026
    </div>

    <h1>
      STREETWEAR<br>
      SUMMER VIBES
    </h1>

    <p>
      Oversize tees, premium fits and fresh summer styles 🔥
    </p>

    <div class="buttons">

      <button class="btn primary-btn">
        Shop Now
      </button>

      <button class="btn secondary-btn">
        View Catalog
      </button>

    </div>

  </div>

  <img
    class="product-image"
    src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?q=80&w=1200&auto=format&fit=crop"
    alt="Streetwear Product"
  />

  <div class="sale-box">

    <small>HOT SALE</small>

    <h2>$500</h2>

    <span>MXN c/u</span>

  </div>

</section>

<section class="section">

  <div class="section-title">
    Featured Products
  </div>

  <div class="products">

    <div class="card">

      <img src="https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?q=80&w=1200&auto=format&fit=crop">

      <div class="card-content">

        <h3>Oversize Tee</h3>

        <p>100% algodón premium</p>

      </div>

    </div>

    <div class="card">

      <img src="https://images.unsplash.com/photo-1523398002811-999ca8dec234?q=80&w=1200&auto=format&fit=crop">

      <div class="card-content">

        <h3>Streetwear Fit</h3>

        <p>Limited collection</p>

      </div>

    </div>

  </div>

</section>

<footer>
  🔥 Share with friends and discover the latest streetwear drop
</footer>

</body>
</html>
